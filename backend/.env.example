# ══════════════════════════════════════════════════════════
# BITE ERP — Variabili d'ambiente
# Copia questo file in .env e compila tutti i valori.
# NON committare mai il file .env — contiene segreti!
#
# Genera segreti casuali con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ══════════════════════════════════════════════════════════

# ── APP ───────────────────────────────────────────────────
APP_NAME=Bite ERP
APP_VERSION=1.0.0
DEBUG=false                           # true solo in sviluppo locale

# Chiavi crittografiche — OBBLIGATORIE, minimo 32 caratteri casuali
SECRET_KEY=GENERA_CON_secrets.token_urlsafe(64)
JWT_SECRET=GENERA_CON_secrets.token_urlsafe(64)

# Frontend — URL base per link nelle email (es. reset password)
FRONTEND_BASE_URL=http://localhost    # in produzione: https://tuodominio.com

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# ── DATABASE ──────────────────────────────────────────────
# Usate sia dal container PostgreSQL che dal backend.
# Genera una password forte: python -c "import secrets; print(secrets.token_urlsafe(24))"
# ATTENZIONE: cambiare queste credenziali su DB esistente richiede:
#   docker exec bite_erp_db psql -U <POSTGRES_USER> -c "ALTER USER <user> PASSWORD '<nuova>';"
POSTGRES_USER=bite
POSTGRES_PASSWORD=GENERA_PASSWORD_FORTE
POSTGRES_DB=bite_erp

DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── BACKUP DATABASE ───────────────────────────────────────
# Numero di giorni di backup da conservare (il servizio db_backup li ruota)
BACKUP_RETAIN_DAYS=7

# ── ADMIN BOOTSTRAP ───────────────────────────────────────
# Crea l'utente admin al primo avvio se il DB è vuoto
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_EMAIL=admin@bite.com
BOOTSTRAP_ADMIN_PASSWORD=SCEGLI_PASSWORD_SICURA_MIN_12_CHARS
BOOTSTRAP_ADMIN_NOME=Admin
BOOTSTRAP_ADMIN_COGNOME=Bite
AUTO_CREATE_MISSING_TABLES=True

# ── FATTURE IN CLOUD ──────────────────────────────────────
FIC_API_KEY=
FIC_BASE_URL=https://api.fattureincloud.it/v2
FIC_OAUTH_CLIENT_ID=
FIC_OAUTH_CLIENT_SECRET=
FIC_OAUTH_REDIRECT_URI=
FIC_COMPANY_ID=
FIC_ACCESS_TOKEN=
FIC_REFRESH_TOKEN=
FIC_SYNC_SCHEDULE_ENABLED=true

# ── CLICKUP ───────────────────────────────────────────────
CLICKUP_API_TOKEN=
CLICKUP_BASE_URL=https://api.clickup.com/api/v2
CLICKUP_TEAM_ID=

# ── ANTHROPIC (Claude AI) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── MAIL (Gmail App Password) ─────────────────────────────
# Genera App Password su: https://myaccount.google.com/apppasswords
MAIL_USERNAME=tua@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=tua@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False
